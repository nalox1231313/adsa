local scanStartTime = tick()

local function scanForCommunication(parent, prefix, parentName)
    prefix = prefix or ""
    parentName = parentName or "Root"
    
    for _, child in pairs(parent:GetChildren()) do
        if child:IsA("RemoteEvent") then
            table.insert(allRemotes.events, {
                name = child.Name,
                path = prefix .. child.Name,
                parent = parentName,
                type = "RemoteEvent"
            })
            print("[SCANNER] 📤 RemoteEvent: " .. prefix .. child.Name)
        elseif child:IsA("RemoteFunction") then
            table.insert(allRemotes.functions, {
                name = child.Name,
                path = prefix .. child.Name,
                parent = parentName,
                type = "RemoteFunction"
            })
            print("[SCANNER] 📞 RemoteFunction: " .. prefix .. child.Name)
        end
        
        if child:IsA("Folder") then
            scanForCommunication(child, prefix .. child.Name .. "/", child.Name)
        elseif child:IsA("Model") then
            scanForCommunication(child, prefix .. child.Name .. "/", child.Name)
        end
    end
end

