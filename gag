local function generateTextReport()
    local report = "=== COMMUNICATION SCAN REPORT ===\n"
    report = report .. "Scan Time: " .. scanTime .. "s\n"
    report = report .. "RemoteEvents: " .. #allRemotes.events .. "\n"
    report = report .. "RemoteFunctions: " .. #allRemotes.functions .. "\n"
    report = report .. "Timestamp: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n\n"
    
    report = report .. "=== RemoteEvents ===\n"
    for _, remote in ipairs(allRemotes.events) do
        report = report .. "• " .. remote.name .. "\n"
        report = report .. "  Path: " .. remote.path .. "\n"
        report = report .. "  Parent: " .. remote.parent .. "\n"
        report = report .. "  Call: remote:FireServer(...)\n\n"
    end
    
    report = report .. "=== RemoteFunctions ===\n"
    for _, func in ipairs(allRemotes.functions) do
        report = report .. "• " .. func.name .. "\n"
        report = report .. "  Path: " .. func.path .. "\n"
        report = report .. "  Parent: " .. func.parent .. "\n"
        report = report .. "  Call: remote:InvokeServer(...)\n\n"
    end
    
    report = report .. "=== SECURITY REALITY ===\n"
    report = report .. "✅ For game developers: use for internal testing\n"
    report = report .. "❌ For external automation: impossible\n"
    report = report .. "✓ Server validates ALL parameters\n"
    report = report .. "✓ Most calls are checked against player state\n"
    
    return report
end

local function generateJSON()
    local json = "{\n"
    json = json .. '  "meta": {\n'
    json = json .. '    "scanTime": ' .. scanTime .. ',\n'
    json = json .. '    "timestamp": "' .. os.date("%Y-%m-%d %H:%M:%S") .. '",\n'
    json = json .. '    "remoteEventCount": ' .. #allRemotes.events .. ',\n'
    json = json .. '    "remoteFunctionCount": ' .. #allRemotes.functions .. '\n'
    json = json .. '  },\n'
    
    json = json .. '  "remoteEvents": [\n'
    for i, remote in ipairs(allRemotes.events) do
        json = json .. '    {\n'
        json = json .. '      "name": "' .. remote.name .. '",\n'
        json = json .. '      "path": "' .. remote.path .. '",\n'
        json = json .. '      "parent": "' .. remote.parent .. '",\n'
        json = json .. '      "type": "RemoteEvent"\n'
        json = json .. '    }' .. (i < #allRemotes.events and ',' or '') .. '\n'
    end
    json = json .. '  ],\n'
    
    json = json .. '  "remoteFunctions": [\n'
    for i, func in ipairs(allRemotes.functions) do
        json = json .. '    {\n'
        json = json .. '      "name": "' .. func.name .. '",\n'
        json = json .. '      "path": "' .. func.path .. '",\n'
        json = json .. '      "parent": "' .. func.parent .. '",\n'
        json = json .. '      "type": "RemoteFunction"\n'
        json = json .. '    }' .. (i < #allRemotes.functions and ',' or '') .. '\n'
    end
    json = json .. '  ]\n'
    json = json .. '}'
    
    return json
end

